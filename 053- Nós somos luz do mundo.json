{
  "hino": "53",
  "titulo": "Nós Somos Luz Do Mundo",
  "duracao_mp3": 140.321,
  "speed_scale": 1.0,
  "intro_duration": 10.435,
  "letra": [
    {
      "texto": "Nós somos luz deste do mundo,",
      "inicio": 11.739,
      "fim": 16.907,
      "num_linha": 1,
      "tipo": "verso",
      "num_verso": 1
    },
    {
      "texto": "Nos falou o Salvador,",
      "inicio": 16.957,
      "fim": 22.124,
      "num_linha": 2,
      "tipo": "verso",
      "num_verso": 1
    },
    {
      "texto": "E somos sal desta terra, Por Deus, Criador;",
      "inicio": 22.174,
      "fim": 32.457,
      "num_linha": 3,
      "tipo": "verso",
      "num_verso": 1
    },
    {
      "texto": "Ante os homens, devemos sempre brilhar;",
      "inicio": 32.609,
      "fim": 42.891,
      "num_linha": 4,
      "tipo": "verso",
      "num_verso": 1
    },
    {
      "texto": "E as boas obras, ao mundo, poderemos mostrar.",
      "inicio": 43.043,
      "fim": 53.326,
      "num_linha": 5,
      "tipo": "verso",
      "num_verso": 1
    },
    {
      "texto": "Cristo, o Mestre divino nos dá",
      "inicio": 54.13,
      "fim": 59.298,
      "num_linha": 1,
      "tipo": "verso",
      "num_verso": 2
    },
    {
      "texto": "Sempre o Seu saber,",
      "inicio": 59.348,
      "fim": 64.515,
      "num_linha": 2,
      "tipo": "verso",
      "num_verso": 2
    },
    {
      "texto": "Entendimento, virtude, fé, também poder;",
      "inicio": 64.565,
      "fim": 74.848,
      "num_linha": 3,
      "tipo": "verso",
      "num_verso": 2
    },
    {
      "texto": "Pelo Espírito Santo nos guiará;",
      "inicio": 75.0,
      "fim": 85.283,
      "num_linha": 4,
      "tipo": "verso",
      "num_verso": 2
    },
    {
      "texto": "Assim o Seu povo na terra sempre mais brilhará.",
      "inicio": 85.435,
      "fim": 95.717,
      "num_linha": 5,
      "tipo": "verso",
      "num_verso": 2
    },
    {
      "texto": "Deus revelou aos pequenos os segredos",
      "inicio": 96.522,
      "fim": 101.689,
      "num_linha": 1,
      "tipo": "verso",
      "num_verso": 3
    },
    {
      "texto": "Lá do céu.",
      "inicio": 101.739,
      "fim": 106.907,
      "num_linha": 2,
      "tipo": "verso",
      "num_verso": 3
    },
    {
      "texto": "A luz divina, por Cristo, já lhes concedeu;",
      "inicio": 106.957,
      "fim": 117.239,
      "num_linha": 3,
      "tipo": "verso",
      "num_verso": 3
    },
    {
      "texto": "São sábios para servir a Deus, Criador,",
      "inicio": 117.391,
      "fim": 127.674,
      "num_linha": 4,
      "tipo": "verso",
      "num_verso": 3
    },
    {
      "texto": "São luz para o mundo de trevas",
      "inicio": 127.826,
      "fim": 132.993,
      "num_linha": 5,
      "tipo": "verso",
      "num_verso": 3
    },
    {
      "texto": "E têm grande esplendor.",
      "inicio": 133.043,
      "fim": 138.109,
      "num_linha": 6,
      "tipo": "verso",
      "num_verso": 3
    }
  ]
}